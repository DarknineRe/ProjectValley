# PostgreSQL Database Configuration
# You can either supply the pieces below *or* use a single
# DATABASE_URL in the form:
#   postgresql://user:pass@host:port/dbname
# Render will automatically set DATABASE_URL when you provision
the managed database.

DATABASE_URL=postgresql://farmvalley_user:uwif1uW3DVjL3a4042jpBHwNty93qmeH@dpg-d6hq4cma2pns738mf030-a.singapore-postgres.render.com/farmvalley

# the following are only needed if you don't use DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=agricultural_db

# Security
NODE_ENV=production
# Restrict CORS to your frontend domain (leave blank or * for development)
CORS_ORIGIN=https://yourdomain.com
# List of emails that have global admin access
SYSTEM_ADMIN_EMAILS=admin@yourdomain.com

# SMTP — required for OTP emails and password recovery
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
